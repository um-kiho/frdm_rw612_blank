mainmenu "zCube FRDM-RW612 Application"

config APP_LED_APA102
	bool "Use APA102 LED strip instead of SK6812"
	default n
	help
	  Select APA102 (GPIO47=DATA, GPIO48=CLK) instead of the default
	  SK6812 RGBW (GPIO46=DATA single-wire NRZ).

config APP_SENSORS_ENABLE
	bool "Enable I2C sensors (BH1750 + thermal array)"
	default n
	help
	  BH1750 조도 센서(0x23)와 열화상 센서(AMG8833 0x69 또는 MLX90640 0x33)를
	  활성화한다. 열화상 센서는 아래 'Thermal array sensor'에서 택1.
	  FC2 I2C 버스(GPIO16=SDA, GPIO17=SCL)에 물리적으로 연결된 경우에만 y로 설정.
	  미연결 상태에서 활성화해도 각 태스크가 probe 실패 시 스스로 정지한다.

choice
	prompt "Thermal array sensor"
	depends on APP_SENSORS_ENABLE
	default APP_THERMAL_AMG8833
	help
	  FC2 I2C 버스에 연결된 열화상 센서를 택1. 둘은 버스를 공유하므로
	  동시 사용은 하지 않고 선택된 하나만 태스크를 시작한다.

config APP_THERMAL_AMG8833
	bool "AMG8833 (8x8, addr 0x69)"
	help
	  Panasonic AMG8833 Grid-EYE 8x8 열화상 (0x69).

config APP_THERMAL_MLX90640
	bool "MLX90640 (32x24, addr 0x33)"
	help
	  Melexis MLX90640 32x24 열화상 (0x33). 보정 연산으로 픽셀별 °C 산출.

config APP_THERMAL_NONE
	bool "None (BH1750 only)"
	help
	  열화상 센서를 시작하지 않고 BH1750 조도 센서만 사용한다.

endchoice

config APP_MATTER_THREAD_AUTOSTART
	bool "Auto-start Thread (openthread_run) in matter_hub_init"
	depends on NET_L2_OPENTHREAD
	default y
	help
	  matter_hub_init() 에서 openthread_run() 을 호출해 Thread 네트워크를
	  기동(form/join)한다. n 으로 두면 OpenThread 인스턴스/RCP 는 SYS_INIT 에서
	  초기화되지만(15.4 라디오는 idle) 네트워크는 올라오지 않는다.
	  WiFi/15.4 coexistence 격리 진단용: n 으로 빌드해 WiFi 연결이 회복되면
	  15.4 활성 트래픽이 원인임을 확인할 수 있다.

config APP_AUDIO_ES8388
	bool "Enable ES8388 audio codec (I2C volume/mute control)"
	default n
	help
	  ES8388 오디오 코덱을 FC2 I2C(GPIO16=SDA, GPIO17=SCL, addr=0x10)로 초기화한다.
	  볼륨·뮤트 제어만 수행하며, 오디오 재생은 ESP32-A1S가 담당한다.
	  미연결 상태에서 활성화 시 I2C 초기화 실패(ENODEV)가 발생할 수 있다.

source "Kconfig.zephyr"
